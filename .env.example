EXPO_PUBLIC_VEX_API_BASE_URL=https://vexguard.app
EXPO_PUBLIC_VEX_BILLING_RETURN_URL=https://vexguard.app/v1/billing/mobile-return?status=success
EXPO_PUBLIC_VEX_BILLING_FAILED_URL=https://vexguard.app/v1/billing/mobile-return?status=failed
EXPO_PUBLIC_VEX_RELEASE_CHANNEL=production
EXPO_PUBLIC_VEX_UPDATE_CHANNEL=production

# Set this after `eas init` or in EAS Environment Variables.
# OTA updates stay disabled until a real Expo project id is present.
VEX_EAS_PROJECT_ID=
VEX_UPDATES_ENABLED=0
VEX_OTA_PROVIDER=expo-open-ota
VEX_OTA_UPDATE_URL=https://updates.vexguard.app/manifest
VEX_OTA_CODE_SIGNING_CERTIFICATE=./certs/certificate.pem

# Android development builds use this suffix so they can live next to production.
VEX_DEBUG_APPLICATION_ID_SUFFIX=.debug
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_ENVIRONMENT=development
EXPO_PUBLIC_SENTRY_RELEASE=
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
