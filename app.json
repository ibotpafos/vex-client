{
  "expo": {
    "name": "VEX",
    "slug": "vex",
    "scheme": "vexguard",
    "version": "1.0.48",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "ios": {
      "associatedDomains": [
        "applinks:vexguard.app"
      ],
      "supportsTablet": true,
      "bundleIdentifier": "com.vexguard.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#040D11",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "versionCode": 1004849,
      "package": "com.vexguard.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "data": [
            {
              "scheme": "vexguard",
              "host": "auth",
              "pathPrefix": "/callback"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Разрешите VEX использовать Face ID для входа в приложение."
        }
      ],
      [
        "expo-notifications",
        {
          "defaultChannel": "vex_updates"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#020A0B",
          "image": "./assets/splash-icon.png",
          "imageWidth": 160,
          "resizeMode": "contain",
          "android": {
            "backgroundColor": "#020A0B",
            "image": "./assets/splash-icon.png",
            "imageWidth": 160,
            "resizeMode": "contain"
          },
          "ios": {
            "backgroundColor": "#020A0B",
            "image": "./assets/splash-icon.png",
            "imageWidth": 160,
            "resizeMode": "contain"
          }
        }
      ],
      [
        "./modules/vex-vpn/plugin/withVexNativeConfig",
        {
          "authScheme": "vexguard",
          "notificationChannelId": "vex_updates"
        }
      ],
      "./modules/vex-vpn/plugin/withVexVpnIos",
      "expo-router"
    ],
    "extra": {
      "vex": {
        "apiBaseUrl": "https://vexguard.app",
        "appVariant": "production",
        "billingFailedUrl": "https://vexguard.app/v1/billing/mobile-return?status=failed",
        "billingReturnUrl": "https://vexguard.app/v1/billing/mobile-return?status=success",
        "updateChannel": "production"
      },
      "router": {},
      "eas": {
        "projectId": "fd3804d3-63ac-423a-b176-996c2a8ea82b"
      }
    },
    "owner": "generaldigits"
  }
}
