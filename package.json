{
  "name": "vex-client",
  "version": "1.0.53",
  "private": true,
  "main": "expo-router/entry",
  "dependencies": {
    "@expo/ui": "~56.0.18",
    "@sentry/react-native": "^8.14.0",
    "@tanstack/react-query": "^5.101.0",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-deep-link": "^2.4.9",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "clsx": "^2.1.1",
    "expo": "~56.0.12",
    "expo-application": "~56.0.3",
    "expo-constants": "~56.0.18",
    "expo-crypto": "~56.0.4",
    "expo-dev-client": "~56.0.20",
    "expo-haptics": "~56.0.3",
    "expo-linking": "~56.0.14",
    "expo-local-authentication": "~56.0.4",
    "expo-notifications": "~56.0.18",
    "expo-router": "~56.2.11",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-updates": "~56.0.19",
    "expo-web-browser": "~56.0.5",
    "lucide-react-native": "^1.18.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.9.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/react": "~19.2.17",
    "eoas": "^2.3.19",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^56.0.4",
    "tsx": "^4.22.4",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "start:dev-client": "expo start --dev-client",
    "android": "bash scripts/run_with_local_release_cache.sh expo run:android",
    "android:build:debug:fast": "bash scripts/run_with_local_release_cache.sh bash -lc 'cd android && VEX_DEBUG_APPLICATION_ID_SUFFIX=.debug NODE_ENV=development ./gradlew :app:assembleDebug -PreactNativeArchitectures=arm64-v8a -PVEX_ANDROID_FAST_ABI=arm64-v8a'",
    "android:build:local:fast": "bash scripts/android_local_build.sh",
    "eas:build:android:development": "bash scripts/run_with_local_release_cache.sh eas build --platform android --profile development",
    "eas:build:android:local": "bash scripts/run_with_local_release_cache.sh eas build --platform android --profile local --local",
    "eas:build:android:preview": "bash scripts/run_with_local_release_cache.sh eas build --platform android --profile preview",
    "eas:build:android:production": "bash scripts/run_with_local_release_cache.sh eas build --platform android --profile production",
    "eas:build:ios:development": "bash scripts/run_with_local_release_cache.sh eas build --platform ios --profile development",
    "eas:build:ios:preview": "bash scripts/run_with_local_release_cache.sh eas build --platform ios --profile preview",
    "eas:build:ios:production": "bash scripts/run_with_local_release_cache.sh eas build --platform ios --profile production",
    "ota:certs": "bash scripts/expo_open_ota_generate_certs.sh",
    "ota:publish:preview": "bash scripts/publish_ota_update.sh publish preview",
    "ota:publish:production": "bash scripts/publish_ota_update.sh publish production",
    "ota:publish:android:production": "OTA_PLATFORM=android bash scripts/publish_ota_update.sh publish production",
    "ota:publish:ios:production": "OTA_PLATFORM=ios bash scripts/publish_ota_update.sh publish production",
    "ota:republish:production": "bash scripts/publish_ota_update.sh republish production",
    "ota:rollback:production": "bash scripts/publish_ota_update.sh rollback production",
    "eas:update:preview": "npm run ota:publish:preview",
    "eas:update:production": "npm run ota:publish:production",
    "eas:update:republish:production": "npm run ota:republish:production",
    "ios": "expo run:ios",
    "ios:build-amneziawg-bridge": "bash scripts/ios_build_amneziawg_bridge.sh",
    "ios:sync-vpn-extension": "ruby scripts/ios_sync_vpn_extension.rb",
    "ios:sync-live-activity-extension": "ruby scripts/ios_sync_live_activity_extension.rb",
    "ios:preflight": "bash scripts/ios_preflight.sh",
    "web": "expo start --web",
    "web:prod-auth": "bash scripts/start_web_prod_auth.sh",
    "dev:prod-api-proxy": "node scripts/dev_prod_api_proxy.mjs",
    "build:web": "expo export -p web",
    "build:helper": "bash scripts/build_helper.sh",
    "native:macos:build": "bash scripts/build_native_macos_app.sh",
    "native:macos:pkg": "bash scripts/build_native_macos_pkg.sh",
    "native:macos:sparkle": "bash scripts/build_native_macos_sparkle_release.sh",
    "native:macos:release": "bash scripts/build_native_macos_local_release.sh",
    "native:macos:deploy-release": "bash scripts/release_native_macos_autonomous.sh",
    "native:macos:internal-release": "bash scripts/build_native_macos_internal_release.sh",
    "native:macos:preflight": "bash scripts/native_macos_production_preflight.sh",
    "desktop:web-bundle": "bash scripts/build_desktop_web_bundle.sh",
    "desktop:storage-smoke": "bash scripts/macos_keychain_sensitive_storage_smoke.sh",
    "desktop:launch-smoke": "npm run native:macos:preflight",
    "tauri:cli": "tauri",
    "expo:doctor": "npx expo-doctor@latest",
    "expo:fix": "npx expo install --fix",
    "typecheck": "tsc --noEmit",
    "test:unit": "tsx tests/run-unit-tests.ts",
    "lint": "eslint .",
    "check": "npm run test:unit && npm run typecheck && npm run lint",
    "ios:signing-preflight": "bash scripts/ios_signing_preflight.sh",
    "ios:device-build": "bash scripts/ios_device_build.sh",
    "versions:sync": "node scripts/sync_versions.mjs",
    "start:web": "expo start --web",
    "android:bootstrap": "bash scripts/bootstrap_amneziawg_android.sh",
    "android:build:local": "bash scripts/android_local_build.sh",
    "android:release": "bash scripts/build_android_release.sh",
    "local:release-cache": "bash scripts/setup_local_release_cache.sh",
    "local:release": "bash scripts/build_all_local_releases.sh",
    "windows:release": "powershell -ExecutionPolicy Bypass -File scripts/build_windows_release.ps1",
    "linux:release": "bash scripts/build_linux_release.sh",
    "macos:release": "npm run native:macos:release"
  },
  "resolutions": {
    "lightningcss": "1.30.1",
    "@expo/fingerprint": "0.19.4"
  },
  "overrides": {
    "uuid": "^11.1.1",
    "@expo/fingerprint": "0.19.4"
  },
  "expo": {
    "autolinking": {
      "include": [
        "@expo/ui"
      ]
    },
    "doctor": {
      "appConfigFieldsNotSyncedCheck": {
        "enabled": false
      }
    },
    "install": {
      "exclude": [
        "@sentry/react-native",
        "react-native-worklets"
      ]
    }
  }
}
