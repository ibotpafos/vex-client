+    /**
+     * Rebind the live userspace tunnel sockets to a new Android network without
+     * replacing the VpnService/TUN interface. This is the safe handover path for
+     * Wi-Fi/cellular transitions because the VPN routes remain installed while
+     * the protected UDP sockets move to the new underlay.
+     */
+    public void bindTunnelSocketsToNetwork(final Network network) throws Exception {
+        if (currentTunnelHandle < 0)
+            throw new IllegalStateException("Tunnel is not running");
+        bindSocketToNetwork(network, awgGetSocketV4(currentTunnelHandle));
+        bindSocketToNetwork(network, awgGetSocketV6(currentTunnelHandle));
+    }
+
+    private static void bindSocketToNetwork(final Network network, final int socketFd) throws Exception {
+        if (socketFd < 0)
+            return;
+        try (final ParcelFileDescriptor socket = ParcelFileDescriptor.fromFd(socketFd)) {
+            network.bindSocket(socket.getFileDescriptor());
+        }
+    }
