{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "VEX",
  "version": "0.1.29",
  "identifier": "app.vex.vpn.desktop",
  "plugins": {
    "updater": {
      "endpoints": [
        "https://vexguard.app/v1/desktop/updater/{{target}}/{{arch}}/{{current_version}}"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI4MUQyMUZFQkU1OTVBMDgKUldRSVdsbSsvaUVkS0FwWWRoTDJUelJ3a3FKRnVFazErblhod0VMOHVLZlMyZkVIVklmZVpMcEgK"
    },
    "deep-link": {
      "desktop": {
        "schemes": [
          "vexguard"
        ]
      }
    }
  },
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8081",
    "beforeDevCommand": "npm run web",
    "beforeBuildCommand": "npm run build:web"
  },
  "app": {
    "windows": [
      {
        "title": "VEX",
        "width": 400,
        "height": 750,
        "resizable": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": "v1Compatible",
    "targets": [
      "app",
      "dmg",
      "nsis",
      "msi"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/amneziawg-go",
      "resources/awg",
      "resources/vex-helper",
      "resources/install-vex-vpn-helper.sh",
      "amneziawg.exe",
      "wintun.dll"
    ],
    "macOS": {
      "signingIdentity": "-"
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
